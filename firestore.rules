rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bulletins/{bulletinId} {

      // Students can read active content. Unpublished resources stay visible only to staff.
      allow read: if isActiveAdvisor(request.auth)
        || (resource.data.isActive == true
          && (!('type' in resource.data)
            || resource.data.type != 'resource'
            || !('isPublished' in resource.data)
            || resource.data.isPublished == true));

      // Only advisors still on the advisor list can create content
      allow create: if isActiveAdvisor(request.auth)
        && validateBulletinData(request.resource.data)
        && request.resource.data.postedBy == getUsername(request.auth.token.email);

      // Original authors can update their own content; admin/leah may update any content.
      allow update: if isActiveAdvisor(request.auth)
        && (isPrivilegedAdvisor(request.auth.token.email)
          || resource.data.postedBy == getUsername(request.auth.token.email))
        && validateBulletinData(request.resource.data)
        && (!('postedBy' in request.resource.data) || request.resource.data.postedBy == resource.data.postedBy)
        && (!('datePosted' in request.resource.data) || request.resource.data.datePosted == resource.data.datePosted)
        && (!('createdAt' in request.resource.data) || !('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt);

      // Any active advisor can update the display order of a resource (drag-to-reorder).
      // Only resourceOrder and updatedAt may change; everything else must remain identical.
      allow update: if isActiveAdvisor(request.auth)
        && resource.data.type == 'resource'
        && request.resource.data.type == 'resource'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resourceOrder', 'updatedAt'])
        && (request.resource.data.resourceOrder == null
          || ((request.resource.data.resourceOrder is int || request.resource.data.resourceOrder is float)
            && request.resource.data.resourceOrder >= 0
            && request.resource.data.resourceOrder <= 100000));

      // Privileged advisors can permanently delete any bulletin. Authors may delete
      // their own inactive placeholders (cancelled or failed publish drafts).
      allow delete: if isActiveAdvisor(request.auth)
        && (isPrivilegedAdvisor(request.auth.token.email)
          || (resource.data.isActive == false
            && resource.data.postedBy == getUsername(request.auth.token.email)));
    }

    match /users/{username} {
      // Users can read and write their own user document
      allow read, write: if request.auth != null
        && request.auth.token.email.matches('.*@ebhcs\\.org')
        && username == getUsername(request.auth.token.email);

      // Admin can read/write any user document
      allow read, write: if request.auth != null
        && request.auth.token.email == 'admin@ebhcs.org';
    }

    match /advisors/{username} {
      // Any active advisor can read the advisors list
      allow read: if isActiveAdvisor(request.auth);

      // Only privileged advisors can create, update, or delete advisor records
      allow write: if request.auth != null
        && isPrivilegedAdvisor(request.auth.token.email);
    }

    match /config/studentDirectory {
      // The student-facing advisor directory (names, titles, contact emails).
      // Published from the admin Advisors tab; the student site falls back to
      // the static list in src/advisor-directory.js when this doc is absent.
      allow read: if true;
      allow write: if request.auth != null
        && isPrivilegedAdvisor(request.auth.token.email)
        && request.resource.data.advisors is list
        && request.resource.data.advisors.size() <= 50;
    }

    match /analyticsEvents/{eventId} {
      // Engagement analytics have been removed to keep Firestore costs low.
      allow read, write: if false;
    }

    match /errors/{errorId} {
      // Public clients can append sanitized runtime errors for monitoring.
      allow create: if validateClientError(request.resource.data);

      // Active advisors can review error logs in Firebase Console.
      allow read: if isActiveAdvisor(request.auth);

      // Error logs are append-only from the public client.
      allow update, delete: if false;
    }

    function getUsername(email) {
      return email.split('@')[0];
    }

    function isAdvisor(authInfo) {
      return authInfo != null
        && authInfo.token.email.matches('.*@ebhcs\\.org');
    }

    // An advisor is "active" only while their advisors/{username} doc exists.
    // Removing an advisor in the portal (Advisors tab -> Remove) therefore
    // revokes their write access immediately, even if their Firebase Auth
    // login still exists. Privileged admins are exempt so the accounts that
    // manage the advisor list can never lock themselves out.
    function isActiveAdvisor(authInfo) {
      return isAdvisor(authInfo)
        && (isPrivilegedAdvisor(authInfo.token.email)
          || exists(/databases/$(database)/documents/advisors/$(getUsername(authInfo.token.email))));
    }

    function isPrivilegedAdvisor(email) {
      return email == 'admin@ebhcs.org' || email == 'leah@ebhcs.org';
    }

    function validActionLinkItem(item) {
      return item.keys().hasAll(['labelEn', 'labelEs'])
        && item.labelEn is string && item.labelEn.size() > 0 && item.labelEn.size() <= 60
        && item.labelEs is string && item.labelEs.size() > 0 && item.labelEs.size() <= 60
        && (!('url' in item) || item.url is string)
        && (!('pdfUrl' in item) || item.pdfUrl is string)
        && (
          (('url' in item) && item.url is string && item.url.size() > 0 && item.url.size() <= 500)
          || (('pdfUrl' in item) && item.pdfUrl is string && item.pdfUrl.size() > 0 && item.pdfUrl.size() <= 500)
        );
    }

    function validActionLinks(links) {
      return links is list && links.size() <= 5
        && (links.size() == 0
          || (validActionLinkItem(links[0])
            && (links.size() < 2 || validActionLinkItem(links[1]))
            && (links.size() < 3 || validActionLinkItem(links[2]))
            && (links.size() < 4 || validActionLinkItem(links[3]))
            && (links.size() < 5 || validActionLinkItem(links[4]))));
    }

    function isDocumentResource(data) {
      return ('resourceKind' in data) && data.resourceKind == 'document';
    }

    function validResourceContact(data) {
      return isDocumentResource(data)
        ? (
          (('pdfUrl' in data) && data.pdfUrl is string && data.pdfUrl.size() > 0)
          || (('url' in data) && data.url is string && data.url.size() > 0)
          || (('actionLinks' in data) && validActionLinks(data.actionLinks) && data.actionLinks.size() > 0)
        )
        : (('url' in data) && data.url is string && data.url.size() > 0);
    }

    function validateBulletinData(data) {
      let hasCommonRequired = data.keys().hasAll(['type', 'advisorName', 'postedBy', 'isActive'])
        && data.type is string && data.type in ['post', 'resource']
        && data.advisorName is string && data.advisorName.size() > 0
        && data.postedBy is string && data.postedBy.size() > 0
        && data.isActive is bool;

      let validOptionalFields =
        (!('description' in data) || data.description is string)
        && (!('company' in data) || data.company is string)
        && (!('contact' in data) || data.contact is string)
        && (!('deadline' in data) || data.deadline is string)
        && (!('eventTime' in data) || data.eventTime is string)
        && (!('eventLink' in data) || data.eventLink is string)
        && (!('dateType' in data) || data.dateType is string)
        && (!('eventDate' in data) || data.eventDate is string)
        && (!('eventDates' in data) || (data.eventDates is list && data.eventDates.size() <= 20))
        && (!('startDate' in data) || data.startDate is string)
        && (!('endDate' in data) || data.endDate is string)
        && (!('startTime' in data) || data.startTime is string)
        && (!('endTime' in data) || data.endTime is string)
        && (!('eventLocation' in data) || data.eventLocation is string)
        && (!('classType' in data) || data.classType is string)
        && (!('image' in data) || data.image == null || data.image is string)
        && (!('imageEs' in data) || data.imageEs == null || data.imageEs is string)
        && (!('resourceLogo' in data) || data.resourceLogo == null || data.resourceLogo is string)
        && (!('pdfUrl' in data) || data.pdfUrl == null || data.pdfUrl is string)
        && (!('createdAt' in data) || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt is timestamp)
        && (!('isPublished' in data) || data.isPublished is bool)
        && (!('isPinned' in data) || data.isPinned is bool)
        && (!('hideFromMainFeed' in data) || data.hideFromMainFeed is bool)
        && (!('resourceCategory' in data) || data.resourceCategory is string)
        && (!('resourceIcon' in data) || data.resourceIcon is string)
        && (!('titleEn' in data) || data.titleEn is string)
        && (!('titleEs' in data) || data.titleEs is string)
        && (!('summaryEs' in data) || data.summaryEs is string)
        && (!('url' in data) || data.url is string)
        && (!('address' in data) || data.address is string)
        && (!('phone' in data) || data.phone is string)
        && (!('phoneMode' in data) || data.phoneMode is string)
        && (!('hours' in data) || data.hours is string)
        && (!('languages' in data) || data.languages is list)
        && (!('highlights' in data) || data.highlights is string)
        && (!('services' in data) || data.services is list)
        && (!('serviceChips' in data) || data.serviceChips is list)
        && (!('resourceKind' in data) || data.resourceKind in ['organization', 'document'])
        && (!('actionLinks' in data) || validActionLinks(data.actionLinks))
        && (!('datePosted' in data) || data.datePosted is timestamp)
        && (!('resourceOrder' in data) || data.resourceOrder == null
          || ((data.resourceOrder is int || data.resourceOrder is float)
            && data.resourceOrder >= 0 && data.resourceOrder <= 100000));

      let validPost = data.type == 'post'
        && data.keys().hasAll(['title', 'category'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.category is string && data.category in ['job', 'training', 'college', 'career-fair', 'announcement', 'resource', 'immigration', 'housing', 'health', 'food', 'esol', 'money', 'childcare'];

      let validResource = data.type == 'resource'
        && data.keys().hasAll(['title', 'titleEn', 'category', 'resourceCategory', 'isPublished'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.titleEn is string && data.titleEn.size() > 0 && data.titleEn.size() <= 200
        && (!('titleEs' in data) || data.titleEs.size() <= 200)
        && data.category == 'resource'
        // resourceCategory whitelist — mirrors AUTHORABLE_RESOURCE_CATEGORIES
        // in src/resource-categories.js. scripts/check-resource-categories-sync.mjs
        // (run in prebuild) fails the build if the two lists drift apart.
        && data.resourceCategory in ['immigration', 'jobs', 'housing', 'health', 'food', 'family', 'hse', 'college', 'legal-aid', 'money', 'esol']
        && (!('url' in data) || data.url is string)
        && validResourceContact(data);

      return hasCommonRequired && validOptionalFields && (validPost || validResource);
    }

    function validateClientError(data) {
      return data.keys().hasAll(['type', 'message', 'source', 'page', 'createdAt', 'dayKey'])
        && data.keys().hasOnly(['type', 'message', 'stack', 'filename', 'lineno', 'colno', 'source', 'page', 'userAgent', 'createdAt', 'dayKey'])
        && data.type is string
        && data.type in ['error', 'unhandledrejection']
        && data.message is string
        && data.message.size() > 0
        && data.message.size() <= 500
        && (!('stack' in data) || (data.stack is string && data.stack.size() <= 2000))
        && (!('filename' in data) || (data.filename is string && data.filename.size() <= 200))
        && (!('lineno' in data) || data.lineno == null || data.lineno is int)
        && (!('colno' in data) || data.colno == null || data.colno is int)
        && data.source is string
        && data.source in ['student', 'admin']
        && data.page is string
        && data.page.size() <= 200
        && (!('userAgent' in data) || (data.userAgent is string && data.userAgent.size() <= 300))
        && data.createdAt is timestamp
        && data.dayKey is string
        && data.dayKey.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }
  }
}
