{
  "name": "advisor-bulletin",
  "version": "1.0.0",
  "description": "EBHCS Advisor Bulletin Board",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "prebuild": "node scripts/check-resource-categories-sync.mjs",
    "build": "vite build",
    "deploy": "npm run build && firebase deploy",
    "preview": "vite preview",
    "test": "playwright test",
    "test:mobile": "playwright test --project=mobile",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "import:resources": "node scripts/import-resources.mjs",
    "clear:analytics": "node scripts/clear-analytics-events.mjs --dry-run",
    "clear:analytics:confirm": "node scripts/clear-analytics-events.mjs --confirm"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "pdfjs-dist": "^5.7.284"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "firebase-admin": "^13.10.0",
    "vite": "^8.0.11"
  }
}
